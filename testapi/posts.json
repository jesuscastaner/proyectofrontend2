        "userUsername": "asmith",
        "userProfilePic": "https://picsum.photos/200/300?random=2",
        "content": "Creo que subestimamos lo importante que es escribir tests hasta que algo se rompe en producción.",
        "replyToId": null,
        "repostOfId": null,
        "isVisible": true,
        "createdAt": "2026-03-28T10:26:00Z",
