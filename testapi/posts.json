        "userUsername": "pparker",
        "userProfilePic": "https://picsum.photos/200/300?random=6",
        "content": "Hoy he optimizado un proceso que tardaba varios segundos y ahora apenas tarda milisegundos.",
        "replyToId": null,
        "repostOfId": null,
        "isVisible": true,
        "createdAt": "2026-03-28T10:25:00Z",
