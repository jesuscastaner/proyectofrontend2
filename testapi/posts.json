        "userId": 3,
        "userDisplayName": "Bruce Wayne",
        "userUsername": "bwayne",
        "userProfilePic": "https://picsum.photos/200/300?random=3",
        "content": "Exacto, especialmente en proyectos grandes donde la mantenibilidad es crítica.",
        "replyToId": 21,
        "repostOfId": null,
        "isVisible": true,
        "createdAt": "2026-03-28T10:21:00Z",
        "updatedAt": "2026-03-28T10:21:00Z"
    },
